{
  "name": "lanscape-ui",
  "private": true,
  "version": "0000.00.00.000000",
  "description": "lanscape-ui is the react app for LANscape python",
  "author": {
    "name": "Michael Dennis",
    "email": "lanscape@dipduo.com"
  },
  "license": "GNU General Public License v3.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "stamp": "node scripts/stamp-version.js --force",
    "dev": "vite",
    "dev:electron": "vite & electron .",
    "build": "npm run stamp && tsc -p tsconfig.app.json && vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/rename-cjs.js",
    "build:all": "npm run build && npm run build:electron",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "npm run build:electron && electron .",
    "pack": "npm run build:all && electron-builder --dir",
    "dist": "npm run build:all && electron-builder",
    "dist:win": "npm run build:all && electron-builder --win",
    "dist:mac": "npm run build:all && electron-builder --mac",
    "dist:linux": "npm run build:all && electron-builder --linux"
  },
  "dependencies": {
    "@awesome.me/kit-d0b7f59243": "^1.0.8",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "framer-motion": "^12.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-tooltip": "^5.30.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "sass": "^1.97.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0"
  },
  "build": {
    "appId": "com.lanscape.desktop",
    "productName": "LANscape",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/${os}/lanscape-backend/",
        "to": "lanscape-backend/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public/favicon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/favicon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-${os}-Setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-${os}-Portable.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/android-chrome-512x512.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "tar.gz"
      ],
      "icon": "public/android-chrome-512x512.png",
      "category": "Network"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-macOS-${arch}.${ext}"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "deb": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "rpm": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    }
  }
}
